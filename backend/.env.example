# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/storm_alerts

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ─── Admin Setup ──────────────────────────────────────────────────────────────
# First account registered with this email gets the admin role
ADMIN_EMAIL=admin@example.com

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Works with Gmail (use App Password), SendGrid SMTP, Mailgun SMTP, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Storm Alerts <your-email@gmail.com>"

# ─── Optional: Twilio SMS ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# ─── Geocoding ───────────────────────────────────────────────────────────────
# Required by Nominatim's usage policy — use a real email or your app gets blocked
CONTACT_EMAIL=your-email@example.com

# ─── Storm Alert Thresholds ───────────────────────────────────────────────────
MIN_HAIL_SIZE=0.75        # inches  — events below this are ignored
MIN_WIND_SPEED=40         # mph     — events below this are ignored
STORM_CHECK_CRON=0 */6 * * *   # every 6 hours
DAYS_BACK=2               # how many days back to pull NOAA data on each run
